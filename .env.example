# Which open letter to serve. Must match a directory under config/letters/
# (e.g. "gehaltsdeckel", "example"). Selects content, branding, theme, emails
# and feature flags. Default: gehaltsdeckel.
LETTER_CONFIG=gehaltsdeckel

# SQLite (SQLCipher, encrypted at rest). Path to the database file.
DATABASE_PATH=./data/diaetendeckel.db
# Required — SQLCipher passphrase. The app refuses to start without it.
DATABASE_ENCRYPTION_KEY=change-me-to-a-long-random-secret
# Optional — path to the SQLCipher shared library. Defaults per platform
# (macOS: /opt/homebrew/lib/libsqlcipher.dylib, Linux: /usr/lib/libsqlcipher.so).
# SQLCIPHER_LIB=/opt/homebrew/lib/libsqlcipher.dylib
# Optional — separate key for encrypted backups (defaults to DATABASE_ENCRYPTION_KEY).
# BACKUP_ENCRYPTION_KEY=
# One-time migration only: connection string of the OLD Postgres database.
# SOURCE_DATABASE_URL=postgres://user:password@host:5432/diaetendeckel
# Path to the Honker SQLite extension (durable jobs). Defaults per platform
# (macOS: ./vendor/libhonker_ext.dylib, Linux: /app/vendor/libhonker_ext.so).
# HONKER_EXTENSION_PATH=./vendor/libhonker_ext.dylib
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
ADMIN_PATH=replace-with-secret-segment
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret
# Email transport. Either "resend" (default) or "smtp". Overrides
# email.provider in the active letter config. Leave unset to use the config value.
# EMAIL_PROVIDER=resend
# Optional sender override for either provider (alias of RESEND_FROM).
# EMAIL_FROM=noreply@gehaltsdeckel.jetzt

# --- Resend (when provider=resend) ---
RESEND_API_KEY=re_your_api_key
RESEND_FROM=noreply@gehaltsdeckel.jetzt

# --- SMTP (when provider=smtp) — any SMTP provider ---
# Host/port/secure may also be set in the letter config (email.smtp); env wins.
# Credentials (user/pass) only ever come from env.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587            # 465 = implicit TLS, 587 = STARTTLS
# SMTP_SECURE=false        # true only for port 465
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password

# --- Send pacing (rate-limit delays, ms) — override email.pacing in the config ---
# EMAIL_MESSAGE_DELAY_MS=550   # between one-by-one sends (zoom link mailing)
# EMAIL_BATCH_DELAY_MS=1000    # between 100-email batch chunks (campaigns, reminders)
# Zoom-Treffen: Termin-Label für die Bestätigungsmail und (optional) der Einwahllink.
# Ist ZOOM_LINK leer, wird die automatische Link-Mail (1 Tag vorher) übersprungen,
# bis der Link gesetzt ist.
ZOOM_EVENT_LABEL=9. Juni, 20 Uhr
ZOOM_LINK=
# Termin als ISO-Zeitstempel MIT Zeitzone (steuert die automatischen Mails:
# 1 Tag vorher Link+ICS, 2 Stunden vorher Erinnerung) und Kalendereintrag-Dauer.
ZOOM_EVENT_AT=2026-06-09T20:00:00+02:00
ZOOM_EVENT_DURATION_MIN=90
